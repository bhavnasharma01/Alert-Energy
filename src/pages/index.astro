---
import BaseLayout from '../layouts/BaseLayout.astro';

// Calculate days remaining dynamically from today's date
const today = new Date();
today.setHours(0, 0, 0, 0);

function daysUntil(dateStr: string): number {
  const target = new Date(dateStr);
  target.setHours(0, 0, 0, 0);
  return Math.ceil((target.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
}

const deadlines = [
  { city: "Washington, D.C.", date: "May 1, 2026", regulation: "BEPS Compliance", daysLeft: daysUntil("2026-05-01") },
  { city: "Chicago, IL", date: "June 1, 2026", regulation: "Energy Benchmarking Ordinance", daysLeft: daysUntil("2026-06-01") },
  { city: "Denver, CO", date: "June 1, 2026", regulation: "Energize Denver", daysLeft: daysUntil("2026-06-01") },
  { city: "Vancouver, BC", date: "June 1, 2026", regulation: "Building Benchmark BC", daysLeft: daysUntil("2026-06-01") },
  { city: "Toronto, ON", date: "July 1, 2026", regulation: "EWRB / EGPS", daysLeft: daysUntil("2026-07-01") },
];
---

<BaseLayout title="Alert Energy - Regulated Benchmarking, Resolved">

  <!-- HERO -->
  <section class="relative bg-navy-500 overflow-hidden">
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="max-w-3xl">
        <p class="text-warm-400 font-semibold text-sm uppercase tracking-widest mb-4">Your Energy Management Partners Since 2014</p>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Energy benchmarking<br/>
          <span class="text-warm-400">without the headache.</span>
        </h1>
        <p class="text-navy-200 text-lg md:text-xl leading-relaxed mb-10 max-w-2xl">
          We have helped owners of millions of square feet of commercial, multifamily, and industrial buildings
          manage all aspects of energy management and reporting. Let us take care of it for you too.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-warm-500 text-white font-semibold rounded-lg hover:bg-warm-600 transition-colors text-lg">
            Let's Talk About Your Building
          </a>
          <a href="/benchmarking" class="inline-flex items-center justify-center px-8 py-4 border-2 border-navy-300 text-navy-200 font-semibold rounded-lg hover:border-white hover:text-white transition-colors text-lg">
            See How We Work
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE CLOCK -->
  <section class="bg-white py-16 border-b border-navy-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-navy-800 mb-3">Upcoming Compliance Deadlines</h2>
        <p class="text-navy-500 max-w-xl mx-auto">Keep track of when your filings are due. We are here to help you stay ahead of every one of these.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {deadlines.map((d) => (
          <div class="bg-navy-50 rounded-xl p-5 text-center border border-navy-100 hover:border-navy-400 transition-colors">
            <p class="text-navy-800 font-semibold text-sm mb-1">{d.city}</p>
            <p class="text-navy-500 font-heading text-2xl font-bold mb-1">{d.date}</p>
            <p class="text-navy-400 text-xs">{d.regulation}</p>
            {d.daysLeft > 0 ? (
              <div class="mt-3 inline-block px-3 py-1 bg-warm-50 text-warm-700 text-xs font-semibold rounded-full">
                {d.daysLeft} {d.daysLeft === 1 ? 'day' : 'days'} left
              </div>
            ) : (
              <div class="mt-3 inline-block px-3 py-1 bg-red-50 text-red-700 text-xs font-semibold rounded-full">
                Deadline passed
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ALERT ENERGY - 3 TRUST PILLARS -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-navy-800 mb-3">Why Building Owners Trust Us</h2>
        <p class="text-navy-500 max-w-2xl mx-auto">We go beyond just filling in forms. We are energy people who genuinely care about getting your numbers right and helping your building perform better.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Pillar 1 -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-100">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-navy-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-800 mb-3">We Get the Numbers Right</h3>
          <p class="text-navy-500 leading-relaxed">
            We use IPMVP standards on every project, which means your data holds up under scrutiny.
            No shortcuts, no guesswork -- just solid numbers you can rely on.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-100">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-navy-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-800 mb-3">We Know the Rules</h3>
          <p class="text-navy-500 leading-relaxed">
            Every city has its own regulations, portals, and quirks. We have worked across cities in the US and Canada,
            and our network of trusted providers means we can support your building wherever it is.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-100">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-navy-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-800 mb-3">We Grow With You</h3>
          <p class="text-navy-500 leading-relaxed">
            Benchmarking is just the starting point. When you are ready for auditing, commissioning,
            or bigger energy projects, we are here for that too.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CLIENT TRUST BAND -->
  <section class="bg-white py-16 border-y border-slate-100">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-center text-navy-400 text-sm font-medium uppercase tracking-widest mb-10">Some of the teams we have worked with</p>

      <div class="flex flex-wrap items-center justify-center gap-12 md:gap-16">
        <div class="flex items-center justify-center h-16">
          <img src="/logos/westfield.svg" alt="Westfield Properties" class="h-10 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        </div>
        <div class="flex items-center justify-center h-16">
          <img src="/logos/macys.png" alt="Macy's" class="h-10 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        </div>
        <div class="flex items-center justify-center h-16">
          <img src="/logos/mandarin-oriental.svg" alt="Mandarin Oriental Hotel Group" class="h-10 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK - PROCESS -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-navy-800 mb-3">How It Works</h2>
        <p class="text-navy-500 max-w-xl mx-auto">We keep things simple. From our first chat to your filed report, we do the heavy lifting so you don't have to.</p>
      </div>

      <div class="grid md:grid-cols-4 gap-6">
        <div class="relative">
          <div class="w-10 h-10 bg-navy-500 text-white font-bold rounded-full flex items-center justify-center mb-4">1</div>
          <h3 class="font-semibold text-navy-800 mb-2">Quick Chat</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            A 15-minute call to learn about your building, where it is, and when your deadline is. No pressure, just a conversation.
          </p>
        </div>
        <div class="relative">
          <div class="w-10 h-10 bg-navy-500 text-white font-bold rounded-full flex items-center justify-center mb-4">2</div>
          <h3 class="font-semibold text-navy-800 mb-2">We Gather the Data</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            We collect your utility bills, building details, and any past filings. We deal with the utility companies so you don't have to.
          </p>
        </div>
        <div class="relative">
          <div class="w-10 h-10 bg-navy-500 text-white font-bold rounded-full flex items-center justify-center mb-4">3</div>
          <h3 class="font-semibold text-navy-800 mb-2">We Crunch the Numbers</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            We enter everything into <a href="https://www.energystar.gov/buildings/benchmark" target="_blank" rel="noopener" class="text-navy-500 hover:text-navy-600 underline">ENERGY STAR Portfolio Manager</a>, check the scores, and get your compliance submission ready.
          </p>
        </div>
        <div class="relative">
          <div class="w-10 h-10 bg-navy-500 text-white font-bold rounded-full flex items-center justify-center mb-4">4</div>
          <h3 class="font-semibold text-navy-800 mb-2">You Get Clear Answers</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            You get your benchmarking report plus honest, practical advice on where your building can do better.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bg-navy-500 py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
        Let's get ahead of your deadline.
      </h2>
      <p class="text-navy-200 text-lg mb-8 max-w-xl mx-auto">
        Whether you need a first-time filing, independent data verification, or a second opinion on last year's submission, we would love to help.
      </p>
      <a href="/contact" class="inline-flex items-center px-8 py-4 bg-warm-500 text-white font-semibold rounded-lg hover:bg-warm-600 transition-colors text-lg">
        Start a Conversation
      </a>
    </div>
  </section>

</BaseLayout>
