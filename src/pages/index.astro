---
import BaseLayout from '../layouts/BaseLayout.astro';

const deadlines = [
  { city: "Washington, D.C.", date: "May 1, 2026", regulation: "BEPS Compliance", daysLeft: 39 },
  { city: "Chicago, IL", date: "June 1, 2026", regulation: "Energy Benchmarking Ordinance", daysLeft: 70 },
  { city: "Denver, CO", date: "June 1, 2026", regulation: "Energize Denver", daysLeft: 70 },
  { city: "Vancouver, BC", date: "June 1, 2026", regulation: "Building Benchmark BC", daysLeft: 70 },
  { city: "Toronto, ON", date: "July 1, 2026", regulation: "EWRB / EGPS", daysLeft: 100 },
];
---

<BaseLayout title="Alert Energy - Regulated Benchmarking, Resolved">

  <!-- HERO -->
  <section class="relative bg-navy-800 overflow-hidden">
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="max-w-3xl">
        <p class="text-amber-400 font-semibold text-sm uppercase tracking-widest mb-4">Optimizing Energy Since 2014</p>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Benchmarking is a requirement.<br/>
          <span class="text-amber-400">Accuracy is an investment.</span>
        </h1>
        <p class="text-navy-200 text-lg md:text-xl leading-relaxed mb-10 max-w-2xl">
          We bring institutional-grade energy expertise to your mandatory compliance filings.
          The same precision trusted by Westfield, Macy's, and Mandarin Oriental -- now available for your building.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-amber-600 text-white font-semibold rounded-lg hover:bg-amber-700 transition-colors text-lg">
            Book Your Compliance Review
          </a>
          <a href="/benchmarking" class="inline-flex items-center justify-center px-8 py-4 border-2 border-navy-400 text-navy-200 font-semibold rounded-lg hover:border-white hover:text-white transition-colors text-lg">
            See How We Work
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE CLOCK -->
  <section class="bg-white py-16 border-b border-navy-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-navy-800 mb-3">Upcoming Compliance Deadlines</h2>
        <p class="text-navy-500 max-w-xl mx-auto">Don't let your filing slip. Here are the next regulated benchmarking deadlines for our coverage cities.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {deadlines.map((d) => (
          <div class="bg-slate-50 rounded-xl p-5 text-center border border-slate-100 hover:border-amber-300 transition-colors">
            <p class="text-navy-800 font-semibold text-sm mb-1">{d.city}</p>
            <p class="text-amber-600 font-heading text-2xl font-bold mb-1">{d.date}</p>
            <p class="text-navy-400 text-xs">{d.regulation}</p>
            <div class="mt-3 inline-block px-3 py-1 bg-amber-50 text-amber-700 text-xs font-semibold rounded-full">
              ~{d.daysLeft} days left
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ALERT ENERGY - 3 TRUST PILLARS -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-navy-800 mb-3">Why Leading Properties Choose Alert Energy</h2>
        <p class="text-navy-500 max-w-2xl mx-auto">We are not a data entry service. We are energy engineers who treat every filing as an audit of your building's performance.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Pillar 1 -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-100">
          <div class="w-12 h-12 bg-navy-800 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-800 mb-3">M&V Rigor</h3>
          <p class="text-navy-500 leading-relaxed">
            We apply IPMVP (International Performance Measurement & Verification Protocol) standards to every
            benchmarking engagement. Your baseline is not just compliant -- it is audit-proof.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-100">
          <div class="w-12 h-12 bg-navy-800 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-800 mb-3">City-Specific Expertise</h3>
          <p class="text-navy-500 leading-relaxed">
            Every jurisdiction has different rules, portals, and penalties. We operate in DC, Chicago, Denver,
            Vancouver, and Toronto -- and know the nuances of each.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-100">
          <div class="w-12 h-12 bg-navy-800 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-800 mb-3">Full Building Lifecycle</h3>
          <p class="text-navy-500 leading-relaxed">
            Benchmarking is just the beginning. Our network handles energy auditing, commissioning,
            procurement design, and systems planning -- so you never outgrow us.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CLIENT TRUST BAND -->
  <section class="bg-white py-16 border-y border-slate-100">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-center text-navy-400 text-sm font-medium uppercase tracking-widest mb-10">Trusted by Industry Leaders</p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <p class="font-heading text-xl font-bold text-navy-800 mb-2">Westfield Properties</p>
          <p class="text-navy-500 text-sm">Multi-property energy compliance across jurisdictions</p>
        </div>
        <div class="text-center p-6">
          <p class="font-heading text-xl font-bold text-navy-800 mb-2">Macy's</p>
          <p class="text-navy-500 text-sm">Enterprise-scale energy accounting and benchmarking</p>
        </div>
        <div class="text-center p-6">
          <p class="font-heading text-xl font-bold text-navy-800 mb-2">Mandarin Oriental Hotels</p>
          <p class="text-navy-500 text-sm">Premium hospitality energy management and reporting</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK - PROCESS -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-navy-800 mb-3">How We Work</h2>
        <p class="text-navy-500 max-w-xl mx-auto">From first conversation to filed report, our process is designed to be hands-off for you.</p>
      </div>

      <div class="grid md:grid-cols-4 gap-6">
        <div class="relative">
          <div class="w-10 h-10 bg-amber-600 text-white font-bold rounded-full flex items-center justify-center mb-4">1</div>
          <h3 class="font-semibold text-navy-800 mb-2">Discovery Call</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            15-minute call to understand your building, jurisdiction, and deadline. We assess your current compliance status.
          </p>
        </div>
        <div class="relative">
          <div class="w-10 h-10 bg-amber-600 text-white font-bold rounded-full flex items-center justify-center mb-4">2</div>
          <h3 class="font-semibold text-navy-800 mb-2">Data Collection</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            We gather your utility bills, building specs, and previous filings. Our team handles the heavy lifting with utility providers.
          </p>
        </div>
        <div class="relative">
          <div class="w-10 h-10 bg-amber-600 text-white font-bold rounded-full flex items-center justify-center mb-4">3</div>
          <h3 class="font-semibold text-navy-800 mb-2">Analysis & Filing</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            We enter data into ENERGY STAR Portfolio Manager, calculate your scores, and prepare the compliance submission.
          </p>
        </div>
        <div class="relative">
          <div class="w-10 h-10 bg-amber-600 text-white font-bold rounded-full flex items-center justify-center mb-4">4</div>
          <h3 class="font-semibold text-navy-800 mb-2">Report & Advise</h3>
          <p class="text-navy-500 text-sm leading-relaxed">
            You receive your benchmarking report plus actionable insights on where your building can improve performance.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bg-navy-800 py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
        Your deadline is approaching.
      </h2>
      <p class="text-navy-200 text-lg mb-8 max-w-xl mx-auto">
        Whether you need a first-time filing or want a second opinion on last year's submission, we are here to help.
      </p>
      <a href="/contact" class="inline-flex items-center px-8 py-4 bg-amber-600 text-white font-semibold rounded-lg hover:bg-amber-700 transition-colors text-lg">
        Get Your Compliance Health Check
      </a>
    </div>
  </section>

</BaseLayout>
